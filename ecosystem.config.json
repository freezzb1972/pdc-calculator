{
  "name": "pdc-calculator",
  "script": "server/src/index.ts",
  "interpreter": "npx",
  "interpreterArgs": "tsx",
  "cwd": "/opt/pdc",
  "env": {
    "NODE_ENV": "production",
    "PORT": 3001
  },
  "instances": 1,
  "exec_mode": "fork",
  "watch": false,
  "max_memory_restart": "500M",
  "error_file": "/var/log/pdc/error.log",
  "out_file": "/var/log/pdc/out.log",
  "merge_logs": true,
  "log_date_format": "YYYY-MM-DD HH:mm:ss",
  "restart_delay": 3000,
  "max_restarts": 10
}
