    "unit":"mm",
    "severity":"warning",
    "version":"GB 50217-2018"
  },
  {
    "rule_code":"GB50217-4.1.3",
    "rule_name":"电缆防火分隔",
    "description":"电缆沟、电缆桥架穿越防火分区处应设防火封堵，重要回路电缆应采用阻燃或耐火电缆",
    "check_formula":"fire_rating >= required_fire_rating",
    "min_value":null,
    "max_value":null,
    "unit":"",
    "severity":"warning",
    "version":"GB 50217-2018"
  },
  {
    "rule_code":"GB50054-3.1.2",
    "rule_name":"多回路N线截面",
    "description":"三相回路N线截面：相线截面≤16mm²时N线与相线等截面，相线截面>16mm²时N线可减半但≥16mm²",
    "check_formula":"n_cross_section >= CASE WHEN phase_cross_section <= 16 THEN phase_cross_section ELSE GREATEST(16, phase_cross_section/2) END",
