    "unit":"V",
    "severity":"error",
    "version":"GB 50052-2009"
  },
  {
    "rule_code":"GB50217-3.6.1",
    "rule_name":"电缆弯曲半径",
    "description":"电缆敷设最小弯曲半径：PVC电缆≥10倍外径，XLPE电缆≥15倍外径，拖链电缆≥7.5倍外径",
    "check_formula":"bend_radius >= min_bend_radius",
