{
  "name": "pdc-calculator",
  "private": true,
  "workspaces": ["client", "server", "scripts"],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm -w server run dev",
    "dev:client": "npm -w client run dev",
    "build": "npm -w server run build && npm -w client run build",
    "start": "npm -w server run start",
    "seed": "npm -w scripts run seed",
    "import-excel": "npm -w scripts run import-excel"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.0"
  }
}
